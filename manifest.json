{
  "manifest_version": 3,
  "name": "Selector",
  "description": "Point at any element, add instructions, and copy a local prompt for AI coding assistants.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/selector-icon.svg",
    "32": "icons/selector-icon.svg",
    "48": "icons/selector-icon.svg",
    "128": "icons/selector-icon.svg"
  },
  "action": {
    "default_title": "Open Selector",
    "default_icon": {
      "16": "icons/selector-icon.svg",
      "32": "icons/selector-icon.svg",
      "48": "icons/selector-icon.svg",
      "128": "icons/selector-icon.svg"
    }
  },
  "background": {
    "service_worker": "assets/service-worker.js"
  },
  "permissions": ["activeTab", "scripting", "contextMenus"],
  "web_accessible_resources": [
    {
      "resources": ["assets/tutorial/placeholder.gif"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "open-selector": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Open Selector on the current page"
    }
  }
}
